{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "bfh3-com",
  "compatibility_date": "2026-06-15",
  "observability": {
    "enabled": true
  },
  "assets": {
    "directory": ".",
    "exclude": [
      "node_modules/**",
      ".git/**",
      ".wrangler/**",
      "*.log"
    ]
  },
  "compatibility_flags": [
    "nodejs_compat"
  ]
}
